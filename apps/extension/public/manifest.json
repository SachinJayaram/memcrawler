{
	"manifest_version": 3,
	"name": "Mem Crawler",
	"short_name": "MemCrawler",
	"version": "0.1.0",
	"description": "Audit and defend your AI memory. Detect injection attacks. Know what persists.",
	"icons": {
		"16": "icons/mc-16.png",
		"48": "icons/mc-48.png",
		"128": "icons/mc-128.png"
	},
	"permissions": [
		"storage",
		"alarms",
		"notifications",
		"activeTab",
		"scripting"
	],
	"host_permissions": [
		"https://chatgpt.com/*",
		"https://*.chatgpt.com/*",
		"https://chat.openai.com/*",
		"https://*.chat.openai.com/*",
		"https://claude.ai/*",
		"https://*.claude.ai/*"
	],
	"optional_host_permissions": ["https://*/*"],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": [
				"https://chatgpt.com/*",
				"https://*.chatgpt.com/*",
				"https://chat.openai.com/*",
				"https://*.chat.openai.com/*"
			],
			"js": ["content/chatgpt.js"],
			"run_at": "document_idle"
		},
		{
			"matches": ["https://claude.ai/*", "https://*.claude.ai/*"],
			"js": ["content/claude.js"],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_popup": "index.html",
		"default_icon": {
			"16": "icons/mc-16.png",
			"48": "icons/mc-48.png"
		},
		"default_title": "Mem Crawler"
	},
	"options_page": "options.html",
	"web_accessible_resources": [
		{
			"resources": ["icons/*"],
			"matches": [
				"https://chatgpt.com/*",
				"https://*.chatgpt.com/*",
				"https://chat.openai.com/*",
				"https://*.chat.openai.com/*",
				"https://claude.ai/*",
				"https://*.claude.ai/*"
			]
		}
	]
}
