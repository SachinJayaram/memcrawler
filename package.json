{
  "name": "mem-crawler",
  "private": true,
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "scripts": {
    "crawler": "node ./apps/cli/dist/cli.js",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:landing": "vite --config vite.landing.config.ts",
    "build:landing": "vite build --config vite.landing.config.ts",
    "lint": "biome lint packages apps",
    "format": "biome format --write packages apps",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
